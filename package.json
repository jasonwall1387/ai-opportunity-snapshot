{
  "name": "ai-opportunity-snapshot",
  "version": "1.0.0",
  "description": "A shareable AI Opportunity Snapshot for local service businesses.",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "type": "module",
  "scripts": {
    "dev": "wrangler types && astro dev",
    "build": "wrangler types && astro check && astro build",
    "check": "astro check && tsc --noEmit",
    "cf-typegen": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "deploy:dry-run": "npm run build && wrangler deploy --dry-run",
    "snapshot": "tsx src/cli/snapshot.ts",
    "snapshot:test": "tsx src/cli/snapshot.ts --fixture",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.10",
    "astro": "^6.4.8",
    "openai": "^6.46.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^25.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.110.0"
  }
}
